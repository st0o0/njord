{
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "Njord": {
    // Open-Meteo needs no API key. The free tier (non-commercial) is assumed;
    // BudgetOverride: { "RequestsPerMonth": ..., "RequestsPerMinute": ... } self-throttles below it.
    "PollInterval": "01:00:00",
    "Locations": [
      { "Name": "borken", "Latitude": 51.8436, "Longitude": 6.8575 },
      { "Name": "winterswijk", "Latitude": 51.9710, "Longitude": 6.7194 }
    ],
    "Models": [
      "icon_seamless",
      "icon_global",
      "icon_eu",
      "icon_d2",
      "gfs_seamless",
      "ecmwf_ifs025",
      "ukmo_seamless",
      "arpege_europe",
      "harmonie_arome_europe",
      "harmonie_arome_netherlands",
      "metno_nordic",
      "gem_seamless",
      "jma_seamless",
      "kma_seamless"
    ],
    // Hours ahead for the per-model HA sensors (entity grid = models × parameters × horizons).
    "Horizons": [ 3, 6, 12, 24, 48, 72 ],
    // Persistence backend: "Sqlite" (default, uses PersistencePath) or "PostgreSql" (requires ConnectionString).
    "Persistence": {
      "Provider": "Sqlite"
    },
    "Mqtt": {
      // Required: the Mosquitto broker (usually the HA host). Startup fails fast when empty.
      "Host": "",
      "Port": 1883,
      // Optional credentials; the password can come from env var Njord__Mqtt__Password.
      "Username": null,
      "DiscoveryPrefix": "homeassistant",
      "BaseTopic": "njord"
    }
  }
}
