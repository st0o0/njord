{
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "Njord": {
    // Open-Meteo needs no API key. The free tier (non-commercial) is assumed;
    // BudgetOverride: { "RequestsPerMonth": ..., "RequestsPerMinute": ... } self-throttles below it.
    // Model ids verified against the live API for the default location (2026-07-11).
    "PollInterval": "01:00:00",
    "Locations": [
      { "Name": "home", "Latitude": 47.05, "Longitude": 8.31 }
    ],
    "Models": [
      "icon_d2",
      "icon_eu",
      "icon_global",
      "ecmwf_ifs025",
      "gfs_seamless",
      "ukmo_global_deterministic_10km",
      "meteoswiss_icon_ch1",
      "meteoswiss_icon_ch2"
    ],
    // Hours ahead for the per-model HA sensors (entity grid = models × parameters × horizons).
    "Horizons": [ 3, 6, 12, 24, 48, 72 ],
    "Mqtt": {
      // Required: the Mosquitto broker (usually the HA host). Startup fails fast when empty.
      "Host": "",
      "Port": 1883,
      // Optional credentials; the password can come from env var Njord__Mqtt__Password.
      "Username": null,
      "DiscoveryPrefix": "homeassistant",
      "BaseTopic": "njord"
    }
  }
}
