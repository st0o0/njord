{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Akka": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Njord": {

    // ── Polling ────────────────────────────────────────────────────────
    // How often each model is polled. The scheduler learns each model's
    // actual update cycle and adjusts, but this sets the Discovery-phase
    // interval and the budget projection baseline.
    // Format: "HH:MM:SS". Must be > 00:00:00.
    "PollInterval": "01:00:00",

    // Number of forecast days requested from Open-Meteo (1–16).
    // Determines the daily day-offset sensors (d0..dN) and the hourly grid depth.
    // More days = slightly higher API call weight (>14 days counts as 2×).
    "ForecastDays": 4,

    // Interval at which models in Discovery phase (unknown update cycle)
    // are re-polled. Once two consecutive data changes are detected the
    // model transitions to Steady phase and uses its learned cycle instead.
    // Format: "HH:MM:SS". Must be > 00:00:00.
    "DiscoveryInterval": "00:20:00",

    // ── Horizons ───────────────────────────────────────────────────────
    // Hours-ahead for the per-model HA sensors.
    // Entity grid = locations × models × parameters × horizons.
    // Each value must be between 1 and 96 (the fetched forecast window).
    // Fewer horizons = fewer HA entities = less MQTT traffic.
    "Horizons": [ 3, 6, 12, 24, 48, 72 ],

    // ── Models ─────────────────────────────────────────────────────────
    // Global model list applied to ALL locations. Free-form Open-Meteo
    // model ids. Unknown ids are allowed (forward-compatible) but will
    // produce HTTP 400 if the API doesn't recognize them.
    //
    // Verified working ids (2026-07-11):
    //   icon_d2              — DWD ICON-D2 (Germany, ~2 km, ~48–64 h)
    //   icon_eu              — DWD ICON-EU (Europe, ~7 km, ~120 h)
    //   icon_global          — DWD ICON Global (~13 km, ~180 h)
    //   ecmwf_ifs025         — ECMWF IFS 0.25° (global, ~240 h)
    //   gfs_seamless         — NOAA GFS Seamless (global, ~384 h)
    //   ukmo_seamless        — UK Met Office Seamless (global, ~168 h)
    //   arpege_europe        — Météo-France ARPEGE (Europe, ~96 h)
    //   knmi_harmonie_arome_europe      — KNMI HARMONIE-AROME Europe (~48 h)
    //   knmi_harmonie_arome_netherlands — KNMI HARMONIE-AROME NL (~48 h)
    //   dmi_harmonie_arome_europe       — DMI HARMONIE-AROME Europe (~60 h)
    //   meteoswiss_icon_ch1  — MeteoSwiss ICON-CH1 (~1 km, Alps, ~33 h)
    //   meteoswiss_icon_ch2  — MeteoSwiss ICON-CH2 (~2 km, Alps, ~45 h)
    "Models": [
      "icon_global",
      "icon_eu",
      "ecmwf_ifs025",
      "gfs_seamless",
      "ukmo_seamless",
      "arpege_europe",
      "knmi_harmonie_arome_europe",
      "dmi_harmonie_arome_europe"
    ],

    // ── Locations ──────────────────────────────────────────────────────
    // At least one location is required. Each location produces its own
    // set of HA devices (one per model).
    //
    // "Models" per location is OPTIONAL — when set, these model ids are
    // MERGED with the global Models list (union, no duplicates).
    // Use this for regional high-resolution models that only cover
    // certain areas (e.g. icon_d2 for Germany, knmi for Netherlands).
    //
    // Validation checks model coverage: a model outside its documented
    // geographic area will cause a startup warning.
    "Locations": [
      {
        "Name": "luzern",
        "Latitude": 47.0502,
        "Longitude": 8.3093,
        "Models": [ "icon_d2", "meteoswiss_icon_ch1", "meteoswiss_icon_ch2" ]
      }
    ],

    // ── Parameters ─────────────────────────────────────────────────────
    // Which Open-Meteo variables to request. Variables are organized in
    // groups; you can also add/exclude individual variables by API name.
    //
    // Groups: "Weather" (30 hourly + 17 daily variables — temperature,
    //         wind, precipitation, clouds, pressure, etc.)
    //         "Solar"   (9 hourly + 4 daily — radiation, UV, sunshine)
    //         "Soil"    (11 hourly + 1 daily — soil temp, moisture, ET)
    //
    // API call weight = ceil(hourly_variable_count / 10). More variables
    // = higher weight = fewer effective requests under the budget.
    // Weather alone = weight 3, all groups = weight 5.
    "Parameters": {
      "Groups": [ "Weather" ],
      "Extra": [],
      "Exclude": []
    },

    // ── Budget ─────────────────────────────────────────────────────────
    // Open-Meteo free tier: 300,000 requests/month, 600/minute.
    // Startup validates that projected usage stays below 80% of the
    // budget. Set BudgetOverride to self-throttle below the free-tier
    // limits (e.g. if sharing the quota with other applications).
    // Omit entirely to use the free-tier defaults.
    //
    // "BudgetOverride": {
    //   "RequestsPerMonth": 100000,
    //   "RequestsPerMinute": 200
    // },

    // ── MQTT ───────────────────────────────────────────────────────────
    "Mqtt": {
      // MQTT is disabled by default (gRPC-only mode).
      // Set to true to connect to a Mosquitto broker and publish
      // HA entities via MQTT Discovery.
      "Enabled": true,

      // REQUIRED when Enabled is true. The Mosquitto broker host
      // (usually the HA host IP). Startup fails fast when empty.
      "Host": "192.168.1.100",
      "Port": 1883,

      // Optional credentials. The password should come from an
      // environment variable (Njord__Mqtt__Password) rather than
      // being stored in this file.
      "Username": null,
      // "Password": null,

      // HA MQTT Discovery prefix. Must match Home Assistant's
      // "discovery_prefix" setting (default: "homeassistant").
      "DiscoveryPrefix": "homeassistant",

      // Set to false to suppress HA discovery config messages.
      // State topics are still published; entities must be created
      // manually or via YAML.
      "DiscoveryEnabled": true,

      // Root topic for njord's own topics:
      //   {BaseTopic}/status              — "online"/"offline" (LWT)
      //   {BaseTopic}/{location}/{model}/{horizon}  — forecast state
      "BaseTopic": "njord"
    },

    // ── Enrichment ─────────────────────────────────────────────────────
    // Each enrichment feature can be independently enabled/disabled.
    // Disabled features produce no HA entities and no MQTT traffic.
    "Enrichment": {

      // Multi-model consensus (median/trimmed mean across all models).
      // Publishes consensus/{horizon} topics with _spread, _agreement,
      // _models_used metadata.
      "Consensus": {
        "Enabled": true,
        // "Median" or "TrimmedMean"
        "Method": "Median",
        // Fraction to trim from each end (only for TrimmedMean).
        "TrimPercent": 0.1
      },

      // Weather alerts derived from forecast data.
      // Publishes alerts/{type} topics with severity, confidence.
      "Alerts": {
        "Enabled": true,
        // Temperature (°C) below which frost alerts trigger.
        "FrostThreshold": 0.0,
        // Temperature (°C) thresholds for heat alerts [yellow, orange, red].
        "HeatThresholds": [ 30, 35, 40 ],
        // Wind gust threshold (m/s) for storm alerts. 16.7 m/s ≈ 60 km/h.
        "StormGustThreshold": 16.7,
        // Precipitation thresholds (mm) for heavy rain alerts.
        "HeavyRainHourlyThreshold": 10.0,
        "HeavyRainDailyThreshold": 25.0,
        // Pressure drop (hPa) over recent hours for weather-change alert.
        "PressureDropThreshold": 5.0,
        // CAPE threshold (J/kg) for thunderstorm risk assessment.
        "CapeThreshold": 1000.0,
        // Combined precipitation + gust thresholds for thunderstorm alerts.
        "ThunderstormPrecipThreshold": 5.0,
        "ThunderstormGustThreshold": 15.0
      },

      // Derived values computed from raw forecast data.
      // Publishes derived/{horizon} topics with beaufort, wind_chill,
      // dewpoint_comfort, wmo_description; derived/meta with
      // diurnal_amplitude, sunshine_pct, inversion.
      "Derived": {
        "Enabled": true
      },

      // Trend analysis comparing consecutive forecast snapshots.
      // Publishes trend data showing how forecasts evolve over time.
      "Trends": {
        "Enabled": false
      },

      // Comfort and degree-day indices.
      // Publishes heating/cooling degree hours, comfort index.
      "Indices": {
        "Enabled": false,
        // Base temperature (°C) for heating degree hours.
        "HeatingBaseTemp": 18.0,
        // Base temperature (°C) for cooling degree hours.
        "CoolingBaseTemp": 24.0,
        // Reference indoor temperature (°C) for comfort calculations.
        "IndoorTemp": 22.0
      },

      // Heat pump energy optimization.
      // Publishes COP estimates, optimal heating hours, degree-hour sums.
      "Energy": {
        "Enabled": false,
        // Heat pump flow temperature (°C) — affects COP calculation.
        "FlowTemp": 35.0,
        // Fraction of Carnot efficiency (0–1). Typical: 0.40–0.50.
        "CarnotEfficiency": 0.45,
        // Outdoor temperature (°C) below which heating is needed.
        "HeatingBaseTemp": 18.0,
        // Number of best-COP hours to recommend for heating runs.
        "CopOptimalHours": 3,
        // Target indoor temperature (°C).
        "IndoorTemp": 22.0
      },

      // Forecast history tracking for anomaly detection.
      // Persists forecast snapshots and computes historical statistics.
      // Requires Akka.Persistence (SQLite or PostgreSQL).
      "History": {
        "Enabled": false,
        // Days of forecast history to retain.
        "RetentionDays": 30,
        // Minimum number of samples before computing statistics.
        "MinSampleSize": 48,
        // Akka.Persistence snapshot interval (every N events).
        "SnapshotInterval": 100
      }
    },

    // ── Persistence ────────────────────────────────────────────────────
    // Backend for Akka.Persistence (scheduler learned cycles, history).
    // "Sqlite" uses PersistencePath below; "PostgreSql" requires
    // ConnectionString.
    "Persistence": {
      "Provider": "Sqlite"
      // "ConnectionString": "Host=localhost;Database=njord;Username=njord;Password=..."
    },

    // File path for the SQLite journal (only used when Provider is Sqlite).
    // Relative to the working directory; in Docker, mount /app/data as a volume.
    "PersistencePath": "data/njord-journal.db"
  }
}
